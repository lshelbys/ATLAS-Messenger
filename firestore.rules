rules_version = '2';

// ATLAS Messenger — Firestore security rules
// Deploy with: `firebase deploy --only firestore:rules`
// (or paste into the Firebase Console → Firestore → Rules.)
//
// Data model:
//   /users/{uid}                       user profile + blockedUsers[]
//   /requests/{auto}                   { from, to, ... }
//   /chats/{cid}                       cid = sorted([uidA, uidB]).join('_')
//                                      { users: [uidA, uidB] }
//   /chats/{cid}/messages/{auto}       { sender, text, timestamp, readBy[], reactions{}, replyTo? }
//   /chats/{cid}/typing/{uid}          ephemeral typing presence

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()   { return request.auth != null; }
    function isSelf(uid)  { return signedIn() && request.auth.uid == uid; }
    function isChatMember(cid) {
      return signedIn() &&
             exists(/databases/$(database)/documents/chats/$(cid)) &&
             request.auth.uid in get(/databases/$(database)/documents/chats/$(cid)).data.users;
    }
    function notBlockedBy(otherUid) {
      // true if `otherUid` has NOT listed me in their blockedUsers array.
      // Use .get('blockedUsers', []) so the rule doesn't crash when the
      // field is absent (which is the default state for any user who has
      // never blocked anyone).
      return !exists(/databases/$(database)/documents/users/$(otherUid))
             || !(request.auth.uid in
                  get(/databases/$(database)/documents/users/$(otherUid)).data.get('blockedUsers', []));
    }

    // ─── users ────────────────────────────────────────────────
    match /users/{uid} {
      // Anyone signed in can read profiles (username lookup, presence, avatars).
      allow read: if signedIn();
      // Owner-only writes; field-shape check.
      allow create: if isSelf(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.email is string
                    && request.resource.data.username is string
                    && request.resource.data.username.matches('^[a-zA-Z0-9_]{3,20}$');
      allow update: if isSelf(uid)
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.email == resource.data.email;
      allow delete: if isSelf(uid);
    }

    // ─── friend requests ──────────────────────────────────────
    // Doc id is deterministic: `${from}_${to}` (e.g. "aliceUid_bobUid").
    // That gives us natural dedup (the same sender can never create two
    // pending requests to the same recipient) without a follow-up query,
    // and lets the list rule depend on a single field so Firestore's
    // query analyzer can verify it.
    match /requests/{rid} {
      // Single-doc fetches: either party may read.
      allow get:    if signedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      // List/query: only the recipient may list, and they must filter by `to == me`.
      allow list:   if signedIn() && resource.data.to == request.auth.uid;
      // Create: doc id must encode the sender→recipient relationship.
      allow create: if signedIn()
                    && rid == request.auth.uid + '_' + request.resource.data.to
                    && request.resource.data.from == request.auth.uid
                    && request.resource.data.to is string
                    && request.resource.data.to != request.auth.uid
                    && notBlockedBy(request.resource.data.to);
      // Recipient (accept) or sender (cancel) may delete.
      allow delete: if signedIn() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      // No updates — a duplicate send tries to setDoc the same id; the app
      // catches the resulting permission-denied and shows "already sent".
      allow update: if false;
    }

    // ─── chats (1:1 and group) ──────────────────────────────
    match /chats/{cid} {
      // Members-only. The app never reads a chat doc it isn't a member of;
      // "is this 1:1 chat already started?" is answered from the local
      // listenChats cache (chatItems map) rather than a getDoc probe.
      allow read: if signedIn() && request.auth.uid in resource.data.users;

      // Create a 1:1 chat (exactly 2 users, both real, other party hasn't blocked me).
      function createOneToOne() {
        return request.resource.data.users.size() == 2
               && !(request.resource.data.isGroup == true)
               && notBlockedBy(request.resource.data.users[0] == request.auth.uid
                               ? request.resource.data.users[1]
                               : request.resource.data.users[0]);
      }
      // Create a group chat (>=2 users, isGroup=true, has a name, creator is a member).
      function createGroup() {
        return request.resource.data.isGroup == true
               && request.resource.data.users.size() >= 2
               && request.resource.data.users.size() <= 100
               && request.resource.data.name is string
               && request.resource.data.name.size() > 0
               && request.resource.data.createdBy == request.auth.uid;
      }
      allow create: if signedIn()
                    && request.resource.data.users is list
                    && request.auth.uid in request.resource.data.users
                    && (createOneToOne() || createGroup());

      // Delete: 1:1 chats can be deleted by either participant ("remove friend").
      // Group chats can only be deleted by the creator. Non-creators leave via update.
      allow delete: if signedIn() && request.auth.uid in resource.data.users
                    && (
                      !(resource.data.isGroup == true) ||
                      resource.data.createdBy == request.auth.uid
                    );

      // Updates: any member can change `ttlSeconds` (disappearing messages).
      // Group members additionally may rename / change photo / leave (shrink users).
      allow update: if signedIn() && request.auth.uid in resource.data.users && (
        // Universal: ttlSeconds only.
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ttlSeconds'])
        ||
        // Group-only mutations.
        (
          resource.data.isGroup == true
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['users', 'name', 'photoURL', 'ttlSeconds'])
          && (
            request.resource.data.users == resource.data.users ||
            request.resource.data.users.toSet().difference(resource.data.users.toSet()).size() == 0
          )
        )
      );

      // ─── messages ─────────────────────────────────────────
      match /messages/{mid} {
        allow read:   if isChatMember(cid);
        allow create: if isChatMember(cid)
                      && request.resource.data.sender == request.auth.uid
                      && request.resource.data.text is string
                      && request.resource.data.text.size() <= 4000;
        // Sender may edit own text; anyone in chat may update `readBy` / `reactions`.
        allow update: if isChatMember(cid) && (
          resource.data.sender == request.auth.uid ||
          // generic field-level updates limited to readBy / reactions
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['readBy', 'reactions'])
        );
        // Delete:
        //  - Sender can always delete their own message.
        //  - In 1:1 chats, either participant can delete any message
        //    (needed for the "Remove friend" flow which wipes the chat).
        //  - In groups, only the sender may delete their message.
        allow delete: if isChatMember(cid) && (
          resource.data.sender == request.auth.uid ||
          !( get(/databases/$(database)/documents/chats/$(cid)).data.isGroup == true )
        );
      }

      // ─── typing presence ──────────────────────────────────
      match /typing/{uid} {
        allow read:   if isChatMember(cid);
        allow write:  if isChatMember(cid) && uid == request.auth.uid;
      }
    }
  }
}
